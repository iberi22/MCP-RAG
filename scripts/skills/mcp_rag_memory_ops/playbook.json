{
  "skill": "mcp-rag-memory-ops",
  "intents": [
    {
      "name": "quick_context_lookup",
      "when": [
        "Preguntas de contexto puntual de codigo",
        "Necesidad de recuperar fragmentos relevantes para una tarea activa"
      ],
      "cli": [
        "python -m cerebro_python rag-search --query \"<query>\" --top-k 8 --project-id <project> --environment-id <env> --scope-mode strict"
      ],
      "mcp": [
        {
          "tool": "rag_search",
          "args": {
            "query": "<query>",
            "top_k": 8,
            "project_id": "<project>",
            "environment_id": "<env>",
            "scope_mode": "strict"
          }
        }
      ]
    },
    {
      "name": "historical_root_cause",
      "when": [
        "Analisis de regresiones",
        "Investigacion de decisiones previas en el codebase"
      ],
      "cli": [
        "git log --date=iso --decorate --graph --max-count 40 --oneline",
        "python scripts/skills/mcp_rag_memory_ops/git_history_ingest.py --max-commits 80 --project-id <project> --environment-id <env>",
        "python -m cerebro_python rag-search --query \"<query>\" --top-k 8 --project-id <project> --environment-id <env> --scope-mode strict"
      ],
      "mcp": [
        {
          "tool": "rag_search",
          "args": {
            "query": "<query> commit regression history blame",
            "top_k": 8,
            "project_id": "<project>",
            "environment_id": "<env>",
            "scope_mode": "strict"
          }
        }
      ]
    },
    {
      "name": "refresh_repo_context",
      "when": [
        "Antes de responder sobre codigo que cambia frecuentemente",
        "Al detectar desactualizacion de contexto"
      ],
      "cli": [
        "python -m cerebro_python rag-sync-repos --config scripts/skills/repo_context_sync/repos.config.json --state .gitcore/repo_context_state.json --cache-dir .cache/repo-context-repos",
        "python -m cerebro_python rag-search --query \"<query>\" --top-k 8 --project-id <project> --environment-id <env> --scope-mode strict"
      ],
      "mcp": [
        {
          "tool": "rag_search",
          "args": {
            "query": "<query>",
            "top_k": 8,
            "project_id": "<project>",
            "environment_id": "<env>",
            "scope_mode": "strict"
          }
        }
      ]
    },
    {
      "name": "cross_stack_investigation",
      "when": [
        "Necesidad explicita de comparar entre stacks o entornos",
        "Analisis de integraciones entre repos"
      ],
      "cli": [
        "python -m cerebro_python rag-search --query \"<query>\" --top-k 8 --project-id <project> --environment-id <env> --scope-mode custom --include-environment-id <other-env>"
      ],
      "mcp": [
        {
          "tool": "rag_search",
          "args": {
            "query": "<query>",
            "top_k": 8,
            "project_id": "<project>",
            "environment_id": "<env>",
            "scope_mode": "custom",
            "include_environment_ids": [
              "<other-env>"
            ]
          }
        }
      ]
    }
  ]
}
