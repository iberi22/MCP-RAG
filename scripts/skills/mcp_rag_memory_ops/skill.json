{
  "name": "mcp-rag-memory-ops",
  "description": "Orquesta el uso correcto de memoria del codebase via CLI y MCP: busqueda contextual, investigacion historica con git y sincronizacion incremental de repos.",
  "entrypoints": {
    "cli_plan": "python -m cerebro_python rag-memory-plan --query \"<pregunta>\" --project-id <project> --environment-id <env>",
    "cli_git_ingest": "python scripts/skills/mcp_rag_memory_ops/git_history_ingest.py --max-commits 80 --project-id <project> --environment-id <env>",
    "cli_repo_sync": "python -m cerebro_python rag-sync-repos --config scripts/skills/repo_context_sync/repos.config.json --state .gitcore/repo_context_state.json --cache-dir .cache/repo-context-repos",
    "mcp_tool": "rag_memory_plan"
  },
  "playbook": "scripts/skills/mcp_rag_memory_ops/playbook.json",
  "guardrails": [
    "default_scope_mode_strict",
    "use_custom_scope_only_when_explicitly_needed",
    "preserve_repo_path_commit_provenance",
    "prefer_incremental_operations_over_full_resync"
  ],
  "capabilities": [
    "intent-routing",
    "memory-context-lookup",
    "git-process-memory-ingestion",
    "repo-context-sync-coordination"
  ]
}
