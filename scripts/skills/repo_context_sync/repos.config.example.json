{
  "defaults": {
    "project_id": "github-repos",
    "environment_id": "prod",
    "tags": [
      "repo-context",
      "github-sync"
    ],
    "max_file_bytes": 300000
  },
  "repositories": [
    {
      "key": "my-org/my-api",
      "url": "https://github.com/my-org/my-api.git",
      "branch": "main",
      "stack": "python",
      "project_id": "stack-python",
      "environment_id": "prod",
      "tags": [
        "stack-python",
        "backend"
      ],
      "include_extensions": [
        ".py",
        ".toml",
        ".yaml",
        ".yml",
        ".md"
      ],
      "exclude_globs": [
        "tests/fixtures/**",
        "docs/archive/**"
      ],
      "max_file_bytes": 250000
    },
    {
      "key": "my-org/my-webapp",
      "url": "https://github.com/my-org/my-webapp.git",
      "branch": "main",
      "stack": "typescript",
      "project_id": "stack-typescript",
      "environment_id": "prod",
      "tags": [
        "stack-typescript",
        "frontend"
      ],
      "include_extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".json",
        ".md"
      ],
      "exclude_globs": [
        "dist/**",
        "storybook-static/**"
      ]
    }
  ]
}
