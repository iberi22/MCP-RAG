# Security: Never commit secrets
*.key filter=secret
*.pem filter=secret
*.p12 filter=secret
*.pfx filter=secret
*_secret* filter=secret
*_key* filter=secret
*.env filter=secret

# Normalize line endings consistently in-repo.
* text=auto eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Database files: Never commit
*.db -text
*.sqlite -text
*.sqlite3 -text
