# ────────────────────────────────────────────────────────────────
# MCP-RAG — Environment variables template (safe to commit)
# Copy to .env and fill in your actual values.
# ────────────────────────────────────────────────────────────────

# ── Adapter Selection ────────────────────────────────────────────
RAG_REPOSITORY_ADAPTER=sqlite
RAG_CHUNKER_ADAPTER=simple
RAG_EMBEDDING_ADAPTER=hash
RAG_RANKER_ADAPTER=hybrid
RAG_MEMORY_POLICY_ADAPTER=smart
RAG_RERANKER_ADAPTER=heuristic
RAG_QUERY_REWRITER_ADAPTER=rules
RAG_SCOPE_STRATEGY_ADAPTER=strict

# ── Storage ──────────────────────────────────────────────────────
RAG_DB_PATH=cerebro_rag.db

# ── Chunking ─────────────────────────────────────────────────────
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_MIN_CHUNK_CHARS=24
RAG_MAX_CHUNKS_PER_DOC=128

# ── Ranking & Retrieval ───────────────────────────────────────────
RAG_SEMANTIC_WEIGHT=0.75
RAG_LEXICAL_WEIGHT=0.25
RAG_RRF_K=50
RAG_MMR_LAMBDA=0.75
RAG_RERANK_BASE_WEIGHT=0.7
RAG_RERANK_LEXICAL_WEIGHT=0.3
RAG_RERANK_PHRASE_BOOST=0.1
RAG_LLM_REWRITE_MAX_TOKENS=96
RAG_LLM_RERANK_TOP_N=20
RAG_LLM_RERANK_WEIGHT=0.45
RAG_RETRIEVAL_MULTIPLIER=5
RAG_MIN_SCORE=-1.0

# ── Ollama (optional, for real embeddings) ────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=nomic-embed-text

# ── MiniMax LLM — Anthropic-compatible API ───────────────────────
# Docs: https://platform.minimax.io/docs/api-reference/text-anthropic-api
MINIMAX_API_KEY=                           # Your MiniMax API key
MINIMAX_MODEL=MiniMax-M2.5-highspeed      # Options: MiniMax-M2.5, MiniMax-M2.1, MiniMax-M2.1-highspeed
MINIMAX_API_HOST=https://api.minimax.io

# ── Cognitive Memory System ───────────────────────────────────────
RAG_COGNITIVE_ENABLED=true
RAG_COGNITIVE_WM_SLOTS=20
RAG_COGNITIVE_PROMOTE_L1_THRESHOLD=0.6
RAG_COGNITIVE_CONSOLIDATE_THRESHOLD=0.75
RAG_COGNITIVE_FORGET_THRESHOLD=0.15
RAG_COGNITIVE_DECAY_LAMBDA=0.02
RAG_COGNITIVE_RECENCY_WEIGHT=0.25
RAG_COGNITIVE_IMPORTANCE_WEIGHT=0.30
RAG_COGNITIVE_RELEVANCE_WEIGHT=0.35
RAG_COGNITIVE_FREQUENCY_WEIGHT=0.10
RAG_COGNITIVE_CONSOLIDATION_MIN_EPISODES=3
RAG_COGNITIVE_DECAY_INTERVAL_HOURS=24
RAG_COGNITIVE_BACKGROUND_ENABLED=true
RAG_COGNITIVE_CONSOLIDATION_INTERVAL_MIN=10
RAG_COGNITIVE_DECAY_INTERVAL_MIN=60
